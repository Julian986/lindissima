# Google Analytics 4 (public; safe to expose in the browser)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Cron (Vercel envía Authorization: Bearer <CRON_SECRET> en los Cron Jobs)
CRON_SECRET=

# Recordatorios WhatsApp: twilio | meta (opcional; si Twilio está completo se usa solo)
WHATSAPP_PROVIDER=twilio

# Twilio WhatsApp (plantilla aprobada → Content SID HX...)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_REMINDER_CONTENT_SID=
# Opcional: quinta variable fija en plantilla {{5}}
# TWILIO_TEMPLATE_BODY_PARAM_5=

# Meta Cloud API (si WHATSAPP_PROVIDER=meta)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_TEMPLATE_NAME=
# WHATSAPP_TEMPLATE_LANG=

# Ventana en minutos alrededor de "24h antes". Default en código: 15.
# Con cron DIARIO (Vercel Hobby) usá 720 (12h) o más, o se pierden turnos.
WHATSAPP_REMINDER_WINDOW_MINUTES=720
